GROK_LAUNCH_BASE_URL=https://api.openai.com/v1
GROK_LAUNCH_MODEL=gpt-4o
# API Key Configuration: Specify either a single key via GROK_LAUNCH_API_KEY or multiple comma-separated keys via GROK_LAUNCH_API_KEYS for rotation.
GROK_LAUNCH_API_KEY=your-api-key-here
# GROK_LAUNCH_API_KEYS=key1,key2,key3
# Upstream protocol: "chat" translates Responses to Chat Completions and supports tools.
# Use "responses" only for upstreams with native Responses API support.
# GROK_LAUNCH_WIRE_API=chat
# Default reasoning effort fallback ("low", "medium", "high" - only for reasoning models)
# GROK_LAUNCH_REASONING_EFFORT=
# Default maximum completion tokens / thinking limit
# GROK_LAUNCH_MAX_COMPLETION_TOKENS=
# Default maximum context length/tokens limit
# GROK_LAUNCH_MAX_TOKENS=
# Optional Grok CLI-side model override. Leave empty to let Grok choose its own default.
# GROK_LAUNCH_CLI_MODEL=

# Add Codex-style upstream request headers when enabled.
# CODEX_HEAD=true
# CODEX_VERSION=0.144.6
# CODEX_BIN=codex
# CODEX_ORIGINATOR=codex_cli_rs
# CODEX_USER_AGENT=
# CODEX_SESSION_ID=
# CODEX_THREAD_ID=
# CODEX_INSTALLATION_ID=
# CODEX_OPENAI_BETA=

# GROK_LAUNCH_PORT=18787
# GROK_LAUNCH_VERBOSE=1
# GROK_BIN=grok
